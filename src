  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding-left: 0;
    padding-right: 40px;
    text-align: left;
    max-width: 800px;
  }

  .hero-tagline {
    font-size: 18px;
    font-weight: 300;
    line-height: 1.5;
    max-width: 520px;
    color: #222;
  }

  .hero-section {
    background: #e68a17;
    padding-top: 40px;
    padding-bottom: 35px;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  .apps-section {
    background: #1a1a1a;
    padding-top: 30px;
  }

  .category-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    gap: 20px;
    padding: 0 20px;
  }

  .category-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .horizontal-slider {
    width: 360px;
    height: 189px;
    border-radius: 26px;
    overflow: hidden;
    background: #111;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.6);
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .horizontal-slider img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .left-slider-pos {
    transform: none;
  }

  .right-slider-pos {
    transform: none;
  }

  .vertical-slider {
    width: 208px;
    height: 360px;
    border-radius: 26px;
    overflow: hidden;
    background: #111;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
    position: relative;
    border: 2px solid rgba(255, 255, 255, 0.1);
  }

  .vertical-slider img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .top-header,
  .header-title,
  .nav-title {
    display: block;
  }

  .header-title {
    color: #e68a17; /* Mustard to match theme but visible on dark bg */
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .app-type-buttons {
    display: flex;
    justify-content: center;
    gap: 18px;
    margin-top: 30px;
    margin-bottom: 25px;
    flex-wrap: wrap;
  }

  .app-type-btn {
    min-width: 240px;
    height: 60px;
    border: none;
    border-radius: 18px;
    font-size: 18px;
    font-weight: 900;
    cursor: pointer;
    color: #ffffff;
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.35);
    transition: transform 0.2s, opacity 0.2s;
  }

  .app-type-btn:active {
    transform: scale(0.98);
  }

  .free-btn {
    background: #7b1fa2;
  }

  .trial-btn {
    background: #d81b60;
  }

  .paid-btn {
    background: #14a3b8;
  }

  .apps-section-title {
    font-size: 28px;
    font-weight: 900;
    text-align: center;
    margin-top: 60px;
    margin-bottom: 30px;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .free-title {
    color: #7b1fa2;
  }

  .trial-title {
    color: #d81b60;
  }

  .paid-title {
    color: #14a3b8;
  }

}
